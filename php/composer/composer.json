{
    "name": "vulnerable/composer-demo",
    "description": "Demo of vulnerable PHP dependencies",
    "type": "project",
    "require": {
        "php": "^8.0",
        "symfony/http-foundation": "5.3.7",
        "symfony/console": "5.3.7",
        "symfony/yaml": "5.3.6",
        "phpmailer/phpmailer": "6.5.0",
        "guzzlehttp/guzzle": "7.3.0",
        "monolog/monolog": "2.3.2",
        "doctrine/dbal": "3.1.1",
        "twig/twig": "3.3.2",
        "vlucas/phpdotenv": "5.3.0",
        "ramsey/uuid": "4.1.1",
        "league/flysystem": "2.2.0",
        "intervention/image": "2.6.1",
        "predis/predis": "1.1.7",
        "firebase/php-jwt": "5.4.0",
        "phpunit/phpunit": "9.5.8",
        "swiftmailer/swiftmailer": "6.2.7",
        "league/commonmark": "2.0.2",
        "psr/log": "1.1.4",
        "psr/http-message": "1.0.1",
        "nikic/php-parser": "4.12.0",
        "phpseclib/phpseclib": "3.0.9",
        "league/csv": "9.7.1",
        "respect/validation": "2.2.3",
        "webmozart/assert": "1.10.0",
        "league/oauth2-client": "2.6.0",
        "egulias/email-validator": "3.1.1",
        "dompdf/dompdf": "1.0.2",
        "mpdf/mpdf": "8.0.12",
        "paragonie/random_compat": "2.0.20",
        "defuse/php-encryption": "2.3.1",
        "league/fractal": "0.19.2",
        "nesbot/carbon": "2.53.1",
        "cocur/slugify": "4.1.0",
        "doctrine/inflector": "2.0.3",
        "symfony/finder": "5.3.7",
        "symfony/filesystem": "5.3.4",
        "symfony/process": "5.3.7",
        "symfony/var-dumper": "5.3.7",
        "psr/cache": "1.0.1",
        "psr/simple-cache": "1.0.1"
    },
    "config": {
        "platform": {
            "php": "8.0.0"
        },
        "sort-packages": true,
        "audit": {
            "block-insecure": false
        }
